library(dslabs)
data(polls_us_election_2016)
my_first <- "Saltuk"
my_birth_year <- 1998
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
data(polls_us_election_2016)
my_birth_year <- 2000
if (k %% 2 == 0) {
head(polls_us_election_2016, k)
} else {
tail(polls_us_election_2016, k)
}
print(total_na)
total_na <- sum(is.na(polls_us_election_2016))
print(total_na)
column_na <- colSums(is.na(polls_us_election_2016))
sequence_column_na <- sort(column_na, decreasing = TRUE)
head(sequence_column_na, 8)
new_data <- polls_us_election_2016
for (col in names(new_data)) {
x <- new_data[[col]]
if (is.numeric(x)) {
x[is.na(x)] <- my_birth_year + k
} else if (is.character(x) | is.factor(x)) {
x[is.na(x)] <- paste0(my_first, "", k)
}
new_data[[col]] <- x
}
for (col in names(new_data)) {
x <- new_data[[col]]
if (is.numeric(x)) {
x[is.na(x)] <- my_birth_year + k
} else if (is.character(x) | is.factor(x)) {
x[is.na(x)] <- paste0(my_first, "", k)
}
new_data[[col]] <- x
}
for (col in names(new_data)) {
x <- new_data[[col]]
if (is.numeric(x)) {
# Sayısal sütunlar aynı kalıyor
x[is.na(x)] <- my_birth_year + k
} else if (is.character(x)) {
# Normal metin sütunları aynı kalıyor
x[is.na(x)] <- paste0(my_first, "", k)
} else if (is.factor(x)) {
# FAKTÖR SÜTUNLARI İÇİN ÇÖZÜM: Önce ismi VIP listesine (levels) ekliyoruz
levels(x) <- c(levels(x), paste0(my_first, "", k))
# Sonra boşlukları dolduruyoruz
x[is.na(x)] <- paste0(my_first, "", k)
}
new_data[[col]] <- x
}
for (col in names(new_data)) {
x <- new_data[[col]]
if (is.numeric(x)) {
x[is.na(x)] <- my_birth_year + k
} else if (is.character(x)) {
x[is.na(x)] <- paste0(my_first, "", k)
} else if (is.factor(x)) {
levels(x) <- c(levels(x), paste0(my_first, "", k))
x[is.na(x)] <- paste0(my_first, "", k)
}
new_data[[col]] <- x
}
```{r}
library(dslabs)
data(polls_us_election_2016)
my_first <- "Saltuk"
my_birth_year <- 2000
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
if (k %% 2 == 0) {
head(polls_us_election_2016, k)
} else {
tail(polls_us_election_2016, k)
}
print(total_na)
column_na <- colSums(is.na(polls_us_election_2016))
sequence_column_na <- sort(column_na, decreasing = TRUE)
head(sequence_column_na, 8)
for (col in names(new_data)) {
x <- new_data[[col]]
if (is.numeric(x)) {
x[is.na(x)] <- my_birth_year + k
} else if (is.character(x)) {
x[is.na(x)] <- paste0(my_first, "", k)
} else if (is.factor(x)) {
levels(x) <- c(levels(x), paste0(my_first, "", k))
x[is.na(x)] <- paste0(my_first, "", k)
}
new_data[[col]] <- x
}
if (k %% 2 == 0) {
head(new_data, k)
} else {
tail(new_data, k)
}
head(new_data, k)
if (k %% 2 == 0) {
head(new_data, k)
} else {
tail(new_data, k)
}
tail(new_data, k)
if (k %% 2 == 0) {
head(new_data, k)
} else {
tail(new_data, k)
}
kalan_na <- sum(is.na(new_data))
print(kalan_na)
print(anyNA(new_data))
print(anyNA(new_data))
